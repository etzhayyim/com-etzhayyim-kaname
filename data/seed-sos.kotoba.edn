 {:en/from "kaname.ent.faith-comm" :en/to "kaname.inst.doctrine"  :en/kind ":influences" :en/domain ":religion" :en/grasping-load 0.70 :en/basis "published accreditation charter §3 (on-record)" :en/sourcing ":representative"}
