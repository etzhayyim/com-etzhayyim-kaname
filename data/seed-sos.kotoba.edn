 {:en/from "kaname.ent.platform"   :en/to "kaname.if.clearing"    :en/kind ":gates" :en/domain ":information"  :en/grasping-load 0.50 :en/sourcing ":representative"}
 {:en/from "kaname.ent.grid"       :en/to "kaname.if.clearing"    :en/kind ":gates" :en/domain ":economy"      :en/grasping-load 0.40 :en/sourcing ":representative"}
 {:en/from "kaname.ent.grid"       :en/to "kaname.if.clearing"    :en/kind ":depends-on" :en/domain ":security" :en/grasping-load 0.50 :en/sourcing ":representative"}

