 {:en/from "kaname.ent.smallco-a"  :en/to "kaname.ent.cap-hoard"  :en/kind ":concentrates" :en/domain ":economy" :en/grasping-load 0.90 :en/sourcing ":representative"}
 {:en/from "kaname.ent.grid"       :en/to "kaname.ent.cap-hoard"  :en/kind ":concentrates" :en/domain ":economy" :en/grasping-load 0.70 :en/sourcing ":representative"}

