 {:en/from "kaname.ent.community"  :en/to "kaname.if.open-commons" :en/kind ":gates" :en/domain ":organization" :en/grasping-load 0.50 :en/sourcing ":representative"}
 {:en/from "kaname.if.open-commons" :en/to "kaname.ent.platform"   :en/kind ":couples" :en/domain ":information" :en/grasping-load 0.50 :en/sourcing ":representative"}

