 ;; public role (person-EXCLUDED — a structural office, not a private profile; G1)
 {:organism/id "kaname.role.accreditor" :organism/kind ":sos/role"      :organism/label "Accreditation Chair (public office)"  :organism/sourcing ":representative" :sos/role "public accreditation office (structural)" :sos/open? false}

