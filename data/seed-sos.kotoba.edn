;; kaname 要 — seed cross-domain SYSTEM-OF-SYSTEMS graph (SYNTHETIC, illustrative — NOT real entities)
;; ADR-2606172100 · the META synthesis layer above the power-mirror lineage.
;;
;; This seed is a small, FICTIONAL multilayer world (G6). Every node is a STRUCTURAL POSITION, never
;; a named real org or person (that join is the G7/Council-gated live leg). It is engineered to make
;; three things demonstrable:
;;   1. one cross-domain INTERFACE (Cross-Domain Accreditation Interface) is the 要 — high
;;      concentration AND spanning many domains AND high bridge → top leverage.
;;   2. a single-domain HOARDER (Capital Concentrator) has high concentration but V=1 → LOW leverage:
;;      concentration ALONE is not the SoS bottleneck (the versatility discriminator).
;;   3. an already-OPEN commons has high concentration+versatility but :sos/open? true → leverage 0
;;      (an open position is not a chokepoint to dissolve).
;;
;; Vocabulary: :organism/* nodes + :en/* 縁 each tagged with a :en/domain layer and a
;; :en/grasping-load ∈ [0,1] (where 取 / connectivity lives; N1). :influences 縁 carry an
;; on-the-record :en/basis (G5). SOURCING :representative — bounded, no fabricated coverage.

[;; ───────────────────────────── nodes ─────────────────────────────
 ;; interfaces (structural decision-points / standards / clearing — the prime 要 candidates)
 {:organism/id "kaname.if.accred"      :organism/kind ":sos/interface"  :organism/label "Cross-Domain Accreditation Interface" :organism/sourcing ":representative" :sos/source-actors [":tsumugi" ":keizu" ":chie"] :sos/open? false}
 {:organism/id "kaname.if.clearing"    :organism/kind ":sos/interface"  :organism/label "Settlement / Clearing Interface"      :organism/sourcing ":representative" :sos/source-actors [":shionome" ":kabuto"]          :sos/open? false}
 {:organism/id "kaname.if.open-commons" :organism/kind ":sos/interface" :organism/label "Open Standards Commons"                :organism/sourcing ":representative" :sos/source-actors [":chie"]                       :sos/open? true}

 ;; instruments (a rule / doctrine that gates flow)
 {:organism/id "kaname.inst.doctrine"  :organism/kind ":sos/instrument" :organism/label "Doctrinal Gatekeeping Institution"     :organism/sourcing ":representative" :sos/source-actors [":tsumugi"]                    :sos/open? false}

 ;; entities (orgs / markets / operators reconciled across domains)
 {:organism/id "kaname.ent.cap-hoard"  :organism/kind ":sos/entity"     :organism/label "Capital Concentrator"                 :organism/sourcing ":representative" :sos/source-actors [":shionome"]                   :sos/open? false}
